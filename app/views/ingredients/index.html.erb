<% content_for :title, "Ingredients" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Ingredients</h1>
    <%= link_to "New ingredient", new_ingredient_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="ingredients" class="bg-white rounded shadow overflow-hidden">
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-100 text-gray-600 text-sm">
          <th class="px-4 py-2 text-left font-medium">Nombre</th>
          <th class="px-4 py-2 text-left font-medium">Unidad</th>
          <th class="px-4 py-2 text-left font-medium">Precio Paquete</th>
          <th class="px-4 py-2 text-left font-medium">Cantdad</th>
          <th class="px-4 py-2 text-left font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="text-gray-800 text-sm">
        <% if @ingredients.any? %>
        <% @ingredients.each do |ingredient| %>
        <tr class="border-b hover:bg-gray-50">

          <td class="px-4 py-2"><%= ingredient.name%></td>
          <td class="px-4 py-2"><%= ingredient.purchase_unit%></td>
          <td class="px-4 py-2"><%= ingredient.purchase_price%></td>
          <td class="px-4 py-2"><%= ingredient.purchase_quantity%></td>
          <td>
            <div class="space-x-2">
              <%= link_to "Show", ingredient, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
              <%= link_to "Edit", edit_ingredient_path(ingredient), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
                <div class="inline-block">
                  <%= button_to "Destroy", ingredient, method: :delete, class: "rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
                </div>
            </div>
          </td>
        </tr>
        <% end %>
        <% else %>
        <div class="alert alert-info ">
          <%= "No objects found" %>
        </div>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
