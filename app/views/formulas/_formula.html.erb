<div id="<%= dom_id formula %>" class="my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Unit:</strong>
    <%= formula.unit %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Quantity:</strong>
    <%= formula.quantity %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Recipe:</strong>
    <%= formula.recipe_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Ingredient:</strong>
    <%= formula.ingredient_id %>
  </div>
</div>
