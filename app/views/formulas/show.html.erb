<h2 class="text-xl font-bold">Ingredientes para <%= @recipe.name %></h2>

<table class="w-full border-collapse border border-gray-300 mt-4">
  <thead>
    <tr class="bg-gray-200">
      <th class="border border-gray-300 px-4 py-2">Ingrediente</th>
      <th class="border border-gray-300 px-4 py-2">Cantidad</th>
      <th class="border border-gray-300 px-4 py-2">Costo</th>
      <th class="border border-gray-300 px-4 py-2">Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @formula_ingredients.each do |formula| %>
      <tr>
        <td class="border border-gray-300 px-4 py-2"><%= formula.ingredient.name %></td>
        <td class="border border-gray-300 px-4 py-2"><%= "#{formula.quantity} #{formula.unit}" %></td>
        <td class="border border-gray-300 px-4 py-2"><%= number_to_currency(formula.cost, unit: "$", separator: ".", delimiter: ",") %></td>
        <td class="border border-gray-300 px-4 py-2 text-center">
          <%#= link_to "✏️ Editar", edit_recipe_formula_path(@recipe, formula), class: "text-blue-600 hover:underline mx-2" %>
          <%#= link_to "❌ Eliminar", recipe_formula_path(@recipe, formula), method: :delete, data: { confirm: "¿Seguro que deseas eliminar este ingrediente?" }, class: "text-red-600 hover:underline mx-2" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<p class="mt-4">
  <%#= link_to "➕ Añadir Ingrediente", new_recipe_formula_path(@recipe), class: "px-4 py-2 bg-green-600 text-white rounded hover:bg-green-500" %>
</p>

<p class="mt-4">
  <%#= link_to "Volver a la lista de recetas", recipes_path, class: "text-blue-600 hover:underline" %>
</p>