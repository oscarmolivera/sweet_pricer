<% content_for :title, "Recipes" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Recipes</h1>
    <%= link_to "New recipe", new_recipe_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="recipes" class="bg-white rounded shadow overflow-hidden">
    <table class="min-w-full">
      <thead>
        <tr class="bg-gray-100 text-gray-600 text-sm">
          <th class="px-4 py-2 text-left font-medium">Nombre</th>
          <th class="px-4 py-2 text-left font-medium">Tipo</th>
          <th class="px-4 py-2 text-left font-medium">Presentación</th>
          <th class="px-4 py-2 text-left font-medium">Porciónes</th>
          <th class="px-4 py-2 text-left font-medium">Costo Receta</th>
          <th class="px-4 py-2 text-left font-medium">Costo Unidad</th>
          <th class="px-4 py-2 text-left font-medium">Ganancia</th>
          <th class="px-4 py-2 text-center font-medium">Acciones</th>
        </tr>
      </thead>
      <tbody class="text-gray-800 text-sm">
        <% if @recipes.any? %>
        <% @recipes.each do |recipe| %>
        <tr class="border-b hover:bg-gray-50">

          <td class="px-4 py-2"><%= recipe.name%></td>
          <td class="px-4 py-2"><%= recipe.recipe_type.capitalize%></td>
          <td class="px-4 py-2"><%= I18n.t("sizes.#{recipe.size}")%></td>
          <td class="px-4 py-2"><%= recipe.portion%></td>
          <td class="px-4 py-2"><%= number_to_currency(recipe.batch_cost, unit: "$", separator: ".", delimiter: ",") %></td>
          <td class="px-4 py-2"><%= number_to_currency(recipe.cost_per_serving, unit: "$", separator: ".", delimiter: ",") %></td>
          <td class="px-4 py-2"><%= number_to_currency(recipe.profit_per_serving, unit: "$", separator: ".", delimiter: ",") %></td>
          <td>
            <div class="space-x-2">
              <%= link_to "Show", recipe_formula_path(recipe, id: recipe.), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
              <%#= link_to "Edit", edit_recipe_path(recipe), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
                <div class="inline-block">
                  <%= button_to "Destroy", recipe, method: :delete, class: "rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
                </div>
            </div>
          </td>
        </tr>
        <% end %>
        <% else %>
        <div class="alert alert-info ">
          <%= "No objects found" %>
        </div>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
